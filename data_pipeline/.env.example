# ==============================================================
# VNPT Money Data Pipeline – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the real .env to version control.
# ==============================================================

# ── Neo4j ──────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jpassword
NEO4J_DATABASE=neo4j

# ── MinIO (Data Lake) ──────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=vnpt-datalake
MINIO_SECURE=0

# ── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── PostgreSQL (Airflow metadata) ──────────────────────────────
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# ── Airflow ────────────────────────────────────────────────────
AIRFLOW_FERNET_KEY=<generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())">
AIRFLOW_SECRET_KEY=<random-string>
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

# ── OpenAI (optional – for embeddings) ────────────────────────
OPENAI_API_KEY=

# ── Notifications (optional) ──────────────────────────────────
SLACK_WEBHOOK_URL=
