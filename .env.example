# =============================================================================
#  VNPT Money Platform – Unified Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit the real .env to version control.
# =============================================================================

# ── Neo4j (shared by pipeline AND chatbot) ─────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jpassword
NEO4J_DATABASE=neo4j

# ── MinIO (Data Lake – DE pipeline only) ───────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=vnpt-datalake
MINIO_SECURE=0

# ── Redis (shared by Airflow broker AND chatbot session cache) ──────────────
REDIS_URL=redis://redis:6379/0

# ── PostgreSQL (Airflow metadata only) ─────────────────────────────────────
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# ── Airflow ─────────────────────────────────────────────────────────────────
# Generate Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=<your-fernet-key>
AIRFLOW_SECRET_KEY=<random-secret-string>
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

# ── Integration Bridge ───────────────────────────────────────────────────────
# Path INSIDE the pipeline/airflow containers where CSVs are exported.
# This maps to ./shared_data/ on the host (see docker-compose.yml volumes).
SHARED_DATA_DIR=/shared_data

# ── OpenAI (required by chatbot for embeddings & LLM responses) ────────────
OPENAI_API_KEY=sk-...

# ── Monitoring ───────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123

# ── Notifications (optional – Airflow DAG slack alerts) ────────────────────
SLACK_WEBHOOK_URL=
